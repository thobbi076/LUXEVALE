{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "images": {
    "domains": ["i.ibb.co", "lh3.googleusercontent.com"],
    "sizes": [640, 750, 828, 1080, 1200, 1920, 2048, 3840],
    "minimumCacheTTL": 60,
    "formats": ["image/avif", "image/webp"]
  }
}
