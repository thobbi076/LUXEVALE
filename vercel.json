{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "images": {
    "domains": ["res.cloudinary.com", "lh3.googleusercontent.com"],
    "sizes": [200, 320, 640, 750, 828, 1080, 1200, 1920, 2048, 3840],
    "minimumCacheTTL": 60,
    "formats": ["image/avif", "image/webp"]
  }
}
